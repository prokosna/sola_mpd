{
	"name": "@sola_mpd/desktop",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "dist/main/index.mjs",
	"scripts": {
		"build": "tsdown",
		"build:no_types": "tsdown",
		"dev": "tsdown && electron dist/main/index.mjs --no-sandbox",
		"start": "electron dist/main/index.mjs",
		"pack": "electron-builder --dir",
		"dist": "electron-builder",
		"test": "vitest run --passWithNoTests",
		"test:e2e": "xvfb-run --auto-servernum playwright test"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.11.0",
		"@connectrpc/connect": "^2.1.1",
		"@connectrpc/connect-node": "^2.1.1",
		"@sola_mpd/shared": "workspace:*",
		"dayjs": "^1.11.20",
		"mpd3": "github:prokosna/mpd.js#1.1.1"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/node": "^24.0.0",
		"electron": "^41.2.0",
		"electron-builder": "^26.8.1",
		"tsdown": "^0.21.7"
	}
}
