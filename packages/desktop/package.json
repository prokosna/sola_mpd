{
	"name": "@sola_mpd/desktop",
	"productName": "sola_mpd",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"main": "dist/main/index.mjs",
	"scripts": {
		"build": "tsdown",
		"build:no_types": "tsdown",
		"dev": "tsdown && ELECTRON_RUN_AS_NODE= electron dist/main/index.mjs --no-sandbox",
		"dist": "node scripts/dist.mjs",
		"test": "vitest run --passWithNoTests",
		"test:e2e": "xvfb-run --auto-servernum playwright test"
	},
	"dependencies": {
		"@bufbuild/protobuf": "^2.12.0",
		"@connectrpc/connect": "^2.1.1",
		"@connectrpc/connect-node": "^2.1.1",
		"@prokosna/mpd3": "^2.0.0",
		"@sola_mpd/shared": "workspace:*",
		"dayjs": "^1.11.20"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@types/node": "^25.6.0",
		"electron": "^41.5.0",
		"electron-builder": "^26.8.1",
		"tsdown": "^0.21.10"
	}
}
