{
	"compilerOptions": {
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"removeComments": true,
		"allowSyntheticDefaultImports": true,
		"target": "ESNext",
		"sourceMap": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"paths": {
			"#backend/*": ["../backend/src/*"]
		}
	},
	"include": ["./src/**/*"]
}
